# Backstage 部署环境变量配置
# 复制此文件为 .env 并修改相应值

# 应用基础 URL（修改为服务器IP或域名）
# 示例: http://192.168.1.100:7007 或 https://backstage.example.com
APP_BASE_URL=http://localhost:7007

# Docker 镜像名称
# 本地构建: backstage:latest
# Docker Hub: your-username/backstage:latest
# 腾讯云 TCR: ccr.ccs.tencentyun.com/namespace/backstage:latest
DOCKER_IMAGE=backstage:latest

# GitHub Token（可选，用于 GitHub 集成）
# GITHUB_TOKEN=your_github_token_here
